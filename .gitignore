# ---------------------------------------------------------------------------
# Credentials & secrets
# ---------------------------------------------------------------------------
.env
.env.local
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
**/.venv/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.installed.cfg
*.egg
dist/

# ---------------------------------------------------------------------------
# IDE
# ---------------------------------------------------------------------------
**/.vscode/
**/.idea/
*.swp
*.swo

# ---------------------------------------------------------------------------
# C++ build artifacts
# ---------------------------------------------------------------------------
cpp_core/build/
cpp_core/out/

# ---------------------------------------------------------------------------
# Model binaries & artifacts (code only in repo)
# ---------------------------------------------------------------------------
models/**
!models/.gitkeep
!models/README.md

# ---------------------------------------------------------------------------
# Local test artifacts
# ---------------------------------------------------------------------------
cpp_core/test_payload.json
src/Untitled

# ---------------------------------------------------------------------------
# Data pipeline outputs
# ---------------------------------------------------------------------------
data/*.parquet
data/*.json

# ---------------------------------------------------------------------------
# Telemetry logs (generated at runtime — never commit mock/production traffic)
# ---------------------------------------------------------------------------
logs/
logs/*.log
logs/**/*.log
!logs/.gitkeep

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
